#!/bin/bash
# wsl-theme-sync — mirror Windows' light/dark theme into Linux toolkits.
#
# WSLg doesn't propagate the host's theme to Linux apps. Reads
# HKCU\SOFTWARE\Microsoft\Windows\CurrentVersion\Themes\Personalize\
# AppsUseLightTheme via reg.exe interop, then writes to whichever
# config sources are useful in this distro:
#
#   tier 1 — gsettings           (only if dconf + GNOME running)
#   tier 2 — GTK 3 settings.ini  (~/.config/gtk-3.0/settings.ini)
#   tier 3 — Qt qt6ct config     (~/.config/qt6ct/qt6ct.conf, if dir exists)
#
# This makes the script DE-agnostic: works on a pure WSLg setup
# (per-app GUI through Windows Start Menu, no compositor), on GNOME,
# on KDE-with-Qt, etc. Each tier no-ops when its config target doesn't
# apply (or doesn't change). Companion .timer fires it every minute,
# so toggling Windows theme propagates within 60s — no app restart
# needed for portal-aware GTK apps.
#
# What we DON'T touch (and why):
#   * GTK4 settings.ini's gtk-application-prefer-dark-theme
#     libadwaita explicitly rejects this key (warns at runtime) and
#     reads color-scheme from the portal/gsettings instead. Writing it
#     was harmless on GTK3, harmful-no-op on GTK4.
#   * env.d GTK_THEME=Adwaita-dark
#     libadwaita refuses to apply its stylesheet when gtk-theme-name
#     is anything but its allowlist (Adwaita, HighContrast, Default,
#     empty). A hammer env override of "Adwaita-dark" turned every
#     libadwaita app into pseudo-fallback CSS — pill buttons rendered
#     as rectangles, Adw.StatusPage illustrations dropped to small
#     symbolic icons. The previous tier-4 fallback was net-harmful.
# Both are actively scrubbed below if found from older revisions.

set -eo pipefail

# Make the script self-sufficient: graft Windows interop dirs onto
# PATH so reg.exe is reachable regardless of how this script was
# launched (login shell, systemd user unit, install-pipeline bash
# subprocess, manual cron, etc). The user-systemd manager only has
# /usr/local/bin:/usr/bin in PATH; login shells get the full Windows
# graft via /etc/profile.d/wsl-integration.sh, but anything else
# doesn't. Without this, `command -v reg.exe` returns nothing in those
# contexts and the script silently exits 0, leaving the theme unchanged.
case ":$PATH:" in
  *":/mnt/c/WINDOWS/system32:"*) ;;
  *) export PATH="$PATH:/mnt/c/WINDOWS/system32" ;;
esac

# Skip if interop is genuinely dead — happens after `wsl --shutdown`
# and before the binfmt drop-in re-registers. Log to stderr so the
# silent-no-op surfaces in the systemd journal instead of disappearing.
if ! command -v reg.exe >/dev/null 2>&1; then
  echo "wsl-theme-sync: reg.exe not on PATH; skipping (interop dead?)" >&2
  exit 0
fi

# Hard-cap reg.exe at 5s. The interop path can hang indefinitely if
# WSLInterop binfmt is wedged or the Windows side is congested —
# without this wrapper the systemd .service never returns, the unit
# stays in `activating start`, and the next minute's .timer fire
# stacks up behind it. `timeout 5` returns 124 on hit; we treat
# that as "no answer this minute, try again later."
#
# Pure-bash field extraction so the script has no awk/gawk runtime
# dep — Fedora WSL's minimal image ships without awk by default.
val=
while IFS= read -r line; do
  case "$line" in
    *AppsUseLightTheme*) val="${line##* }"; break ;;
  esac
done < <(timeout 5 reg.exe query \
           'HKCU\SOFTWARE\Microsoft\Windows\CurrentVersion\Themes\Personalize' \
           /v AppsUseLightTheme 2>/dev/null \
         | tr -d '\r')
if [ -z "$val" ]; then
  echo "wsl-theme-sync: reg.exe returned no AppsUseLightTheme value (timeout? interop slow?); skipping" >&2
  exit 0
fi

case "$val" in
  0x0)  # Dark
    want_scheme=prefer-dark
    want_gtk_prefer_dark=1
    want_qt_style=Adwaita-Dark
    ;;
  0x1)  # Light
    want_scheme=default
    want_gtk_prefer_dark=0
    want_qt_style=Adwaita
    ;;
  *)
    exit 0  # registry indeterminate — silent no-op
    ;;
esac
# gtk-theme is ALWAYS Adwaita — variant comes from color-scheme
# (libadwaita) and gtk-application-prefer-dark-theme (GTK3). See header.
want_gtk=Adwaita

changed=0

# ----- tier 1: gsettings (GNOME) ---------------------------------------
# Only writes when dconf is reachable AND a gnome-shell-ish desktop is
# active — otherwise gsettings would write to a database nobody reads.
if command -v gsettings >/dev/null 2>&1 \
   && [ -n "${XDG_RUNTIME_DIR:-}" ] \
   && [ -S "${XDG_RUNTIME_DIR}/dbus/system_bus_socket" \
        -o -S "${XDG_RUNTIME_DIR}/bus" ]; then
  # Each gsettings call hits the user dbus session bus → dconf-service.
  # If the bus is congested (e.g., portal is crashlooping), these
  # would normally hang for ~25s on dbus's default reply timeout.
  # `timeout 3` per call keeps the whole tier under 10s worst-case.
  #
  # color-scheme and gtk-theme are checked independently so drift in
  # either gets corrected — earlier revisions wrote gtk-theme=Adwaita-dark
  # which sticks in dconf even after the bug fix lands. Without an
  # independent normalization pass, libadwaita stays broken until the
  # user toggles Windows theme.
  cur_scheme=$(timeout 3 gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null \
               | tr -d "'")
  if [ -n "$cur_scheme" ] && [ "$cur_scheme" != "$want_scheme" ]; then
    timeout 3 gsettings set org.gnome.desktop.interface color-scheme "$want_scheme" 2>/dev/null || true
    changed=1
  fi
  cur_gtk=$(timeout 3 gsettings get org.gnome.desktop.interface gtk-theme 2>/dev/null \
            | tr -d "'")
  if [ -n "$cur_gtk" ] && [ "$cur_gtk" != "$want_gtk" ]; then
    timeout 3 gsettings set org.gnome.desktop.interface gtk-theme "$want_gtk" 2>/dev/null || true
    changed=1
  fi
fi

# ----- tier 2: GTK 3 settings.ini --------------------------------------
# Read by every GTK 3 app via the legacy code path. GTK4/libadwaita
# does NOT participate — see header.
write_gtk3_ini() {
  local path=$1 want=$2
  install -d "$(dirname "$path")"
  if [ -f "$path" ]; then
    if grep -q '^\[Settings\]' "$path"; then
      if grep -q '^gtk-application-prefer-dark-theme=' "$path"; then
        local cur
        cur=$(grep '^gtk-application-prefer-dark-theme=' "$path" | tail -1 | cut -d= -f2)
        [ "$cur" = "$want" ] && return 0
        sed -i "s/^gtk-application-prefer-dark-theme=.*/gtk-application-prefer-dark-theme=$want/" "$path"
      else
        sed -i "/^\[Settings\]/a gtk-application-prefer-dark-theme=$want" "$path"
      fi
      changed=1
      return 0
    fi
  fi
  {
    [ -f "$path" ] && cat "$path"
    printf '\n[Settings]\ngtk-application-prefer-dark-theme=%s\n' "$want"
  } > "$path.tmp"
  mv "$path.tmp" "$path"
  changed=1
}
write_gtk3_ini "$HOME/.config/gtk-3.0/settings.ini" "$want_gtk_prefer_dark"

# Forward-fix: scrub gtk-application-prefer-dark-theme from GTK4's
# settings.ini if an older revision wrote it. libadwaita warns about
# the key and the surrounding side-effects break its stylesheet.
gtk4_ini=$HOME/.config/gtk-4.0/settings.ini
if [ -f "$gtk4_ini" ] && grep -q '^gtk-application-prefer-dark-theme=' "$gtk4_ini"; then
  sed -i '/^gtk-application-prefer-dark-theme=/d' "$gtk4_ini"
  # If the file is now just `[Settings]` + whitespace, drop it.
  if ! grep -qvE '^(\[Settings\]|\s*)$' "$gtk4_ini"; then
    rm -f "$gtk4_ini"
  fi
  changed=1
fi

# ----- tier 3: Qt qt6ct.conf ------------------------------------------
# qt6ct is the standard "Qt Configuration Tool" used to set Qt platform
# themes outside of KDE. We only touch the file if its dir already
# exists — installing qt6ct ourselves is out of scope, but if the user
# already has it we keep it in sync.
qt6ct_conf=$HOME/.config/qt6ct/qt6ct.conf
if [ -d "$(dirname "$qt6ct_conf")" ]; then
  if [ ! -f "$qt6ct_conf" ] || ! grep -q "^style=$want_qt_style$" "$qt6ct_conf"; then
    install -d "$(dirname "$qt6ct_conf")"
    if [ -f "$qt6ct_conf" ] && grep -q '^style=' "$qt6ct_conf"; then
      sed -i "s/^style=.*/style=$want_qt_style/" "$qt6ct_conf"
    else
      printf '[Appearance]\nstyle=%s\n' "$want_qt_style" >> "$qt6ct_conf"
    fi
    changed=1
  fi
fi

# ----- forward-fix: drop legacy env.d GTK_THEME ------------------------
# Older revisions wrote GTK_THEME=Adwaita-dark here as a "fallback for
# non-portal-aware apps". That env var is a hard process-wide override
# and disabled libadwaita's stylesheet on every GTK4 app launched from
# the user systemd session. Active cleanup only — we don't write here
# anymore. Also unset it from the live user-manager environment so
# already-inherited shells/apps drop the override on next launch.
env_path=$HOME/.config/environment.d/45-theme.conf
if [ -f "$env_path" ]; then
  rm -f "$env_path"
  changed=1
fi
# Clear GTK_THEME from the live user-manager env independently of the
# file — a previous manager start imported the bad value into the env
# table, so deleting the file alone leaves the table dirty until the
# next wsl --shutdown. `unset-environment` is broken on Fedora 44's
# systemd (exits 0 but leaves the var), so use `set-environment KEY=`
# which works and is treated by GTK as no override. Doesn't reach
# already-running processes (notably gnome-shell-headless) — those
# need a session restart to drop the inherited override.
if command -v systemctl >/dev/null 2>&1 \
   && [ -S "${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/systemd/private" ]; then
  cur_gtk_env=$(timeout 3 systemctl --user show-environment 2>/dev/null \
                | grep '^GTK_THEME=' | cut -d= -f2-)
  if [ -n "$cur_gtk_env" ]; then
    systemctl --user set-environment GTK_THEME= 2>/dev/null || true
    changed=1
  fi
fi

[ "$changed" = "1" ] \
  && echo "wsl-theme-sync: AppsUseLightTheme=$val → gtk=$want_gtk dark=$want_gtk_prefer_dark"
exit 0
