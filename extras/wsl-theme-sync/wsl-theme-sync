#!/bin/bash
# wsl-theme-sync — mirror Windows' light/dark theme into Linux toolkits.
#
# WSLg doesn't propagate the host's theme to Linux apps. Reads
# HKCU\SOFTWARE\Microsoft\Windows\CurrentVersion\Themes\Personalize\
# AppsUseLightTheme via reg.exe interop, then writes to whichever
# config sources are useful in this distro:
#
#   tier 1 — gsettings           (only if dconf + GNOME running)
#   tier 2 — GTK 3 + 4 settings  (~/.config/gtk-{3,4}.0/settings.ini)
#   tier 3 — Qt qt6ct config     (~/.config/qt6ct/qt6ct.conf, if dir exists)
#   tier 4 — env.d GTK_THEME     (~/.config/environment.d/45-theme.conf)
#
# This makes the script DE-agnostic: works on a pure WSLg setup
# (per-app GUI through Windows Start Menu, no compositor), on GNOME,
# on KDE-with-Qt, etc. Each tier no-ops when its config target doesn't
# apply (or doesn't change). Companion .timer fires it every minute,
# so toggling Windows theme propagates within 60s — no app restart
# needed for portal-aware GTK apps.

set -eo pipefail

# Skip silently if interop is dead — happens after `wsl --shutdown`
# and before the binfmt drop-in re-registers.
command -v reg.exe >/dev/null 2>&1 || exit 0

val=$(reg.exe query \
        'HKCU\SOFTWARE\Microsoft\Windows\CurrentVersion\Themes\Personalize' \
        /v AppsUseLightTheme 2>/dev/null \
      | awk '/AppsUseLightTheme/{print $NF}' \
      | tr -d '\r')

case "$val" in
  0x0)  # Dark
    want_scheme=prefer-dark
    want_gtk=Adwaita-dark
    want_gtk_prefer_dark=1
    want_qt_style=Adwaita-Dark
    ;;
  0x1)  # Light
    want_scheme=default
    want_gtk=Adwaita
    want_gtk_prefer_dark=0
    want_qt_style=Adwaita
    ;;
  *)
    exit 0  # registry indeterminate — silent no-op
    ;;
esac

changed=0

# ----- tier 1: gsettings (GNOME) ---------------------------------------
# Only writes when dconf is reachable AND a gnome-shell-ish desktop is
# active — otherwise gsettings would write to a database nobody reads.
if command -v gsettings >/dev/null 2>&1 \
   && [ -n "${XDG_RUNTIME_DIR:-}" ] \
   && [ -S "${XDG_RUNTIME_DIR}/dbus/system_bus_socket" \
        -o -S "${XDG_RUNTIME_DIR}/bus" ]; then
  cur=$(gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null \
        | tr -d "'")
  if [ -n "$cur" ] && [ "$cur" != "$want_scheme" ]; then
    gsettings set org.gnome.desktop.interface color-scheme "$want_scheme"
    gsettings set org.gnome.desktop.interface gtk-theme    "$want_gtk"
    changed=1
  fi
fi

# ----- tier 2: GTK 3 + 4 settings.ini ----------------------------------
# Read by every GTK 3/4 app via the legacy code path. libadwaita apps
# also fall through to this when no portal answers a color-scheme query.
write_gtk_ini() {
  local path=$1 want=$2
  install -d "$(dirname "$path")"
  if [ -f "$path" ]; then
    # Update existing key in [Settings] OR add to file
    if grep -q '^\[Settings\]' "$path"; then
      if grep -q '^gtk-application-prefer-dark-theme=' "$path"; then
        local cur
        cur=$(grep '^gtk-application-prefer-dark-theme=' "$path" | tail -1 | cut -d= -f2)
        [ "$cur" = "$want" ] && return 0
        sed -i "s/^gtk-application-prefer-dark-theme=.*/gtk-application-prefer-dark-theme=$want/" "$path"
      else
        sed -i "/^\[Settings\]/a gtk-application-prefer-dark-theme=$want" "$path"
      fi
      changed=1
      return 0
    fi
  fi
  # File missing or no [Settings] section → write fresh-ish
  {
    [ -f "$path" ] && cat "$path"
    printf '\n[Settings]\ngtk-application-prefer-dark-theme=%s\n' "$want"
  } > "$path.tmp"
  mv "$path.tmp" "$path"
  changed=1
}
write_gtk_ini "$HOME/.config/gtk-3.0/settings.ini" "$want_gtk_prefer_dark"
write_gtk_ini "$HOME/.config/gtk-4.0/settings.ini" "$want_gtk_prefer_dark"

# ----- tier 3: Qt qt6ct.conf ------------------------------------------
# qt6ct is the standard "Qt Configuration Tool" used to set Qt platform
# themes outside of KDE. We only touch the file if its dir already
# exists — installing qt6ct ourselves is out of scope, but if the user
# already has it we keep it in sync.
qt6ct_conf=$HOME/.config/qt6ct/qt6ct.conf
if [ -d "$(dirname "$qt6ct_conf")" ]; then
  if [ ! -f "$qt6ct_conf" ] || ! grep -q "^style=$want_qt_style$" "$qt6ct_conf"; then
    install -d "$(dirname "$qt6ct_conf")"
    if [ -f "$qt6ct_conf" ] && grep -q '^style=' "$qt6ct_conf"; then
      sed -i "s/^style=.*/style=$want_qt_style/" "$qt6ct_conf"
    else
      printf '[Appearance]\nstyle=%s\n' "$want_qt_style" >> "$qt6ct_conf"
    fi
    changed=1
  fi
fi

# ----- tier 4: env.d GTK_THEME (fallback for non-portal-aware apps) ---
env_path=$HOME/.config/environment.d/45-theme.conf
expected="GTK_THEME=$want_gtk"
if [ ! -f "$env_path" ] || ! grep -q "^$expected$" "$env_path"; then
  install -d "$(dirname "$env_path")"
  printf '# Auto-managed by wsl-theme-sync — do not edit by hand.\n%s\n' "$expected" > "$env_path"
  changed=1
fi

[ "$changed" = "1" ] \
  && echo "wsl-theme-sync: AppsUseLightTheme=$val → gtk=$want_gtk dark=$want_gtk_prefer_dark"
exit 0
